{
  "name": "envdrift-vscode",
  "displayName": "EnvDrift - Auto Encrypt .env Files",
  "description": "Automatically encrypt .env files when closed using envdrift",
  "version": "0.1.5",
  "publisher": "envdrift",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jainal09/envdrift"
  },
  "homepage": "https://github.com/jainal09/envdrift/tree/main/envdrift-vscode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "env",
    "dotenv",
    "encrypt",
    "dotenvx",
    "security"
  ],
  "activationEvents": [
    "workspaceContains:**/.env",
    "workspaceContains:**/.env.*",
    "workspaceContains:**/envdrift.toml",
    "onCommand:envdrift.enable",
    "onCommand:envdrift.disable",
    "onCommand:envdrift.encryptNow",
    "onCommand:envdrift.showStatus",
    "onCommand:envdrift.showLogs",
    "onCommand:envdrift.startAgent",
    "onCommand:envdrift.stopAgent",
    "onCommand:envdrift.refreshAgentStatus"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "EnvDrift only shows status and agent UI in untrusted workspaces. Automatic and manual encryption (which runs the envdrift binary against workspace files) is disabled until you trust the workspace.",
      "restrictedConfigurations": [
        "envdrift.enabled"
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "envdrift.enable",
        "title": "EnvDrift: Enable Auto-Encryption"
      },
      {
        "command": "envdrift.disable",
        "title": "EnvDrift: Disable Auto-Encryption"
      },
      {
        "command": "envdrift.encryptNow",
        "title": "EnvDrift: Encrypt Current File"
      },
      {
        "command": "envdrift.showStatus",
        "title": "EnvDrift: Show Status"
      },
      {
        "command": "envdrift.showLogs",
        "title": "EnvDrift: Show Logs"
      },
      {
        "command": "envdrift.startAgent",
        "title": "EnvDrift: Start Background Agent"
      },
      {
        "command": "envdrift.stopAgent",
        "title": "EnvDrift: Stop Background Agent"
      },
      {
        "command": "envdrift.refreshAgentStatus",
        "title": "EnvDrift: Refresh Agent Status"
      }
    ],
    "configuration": {
      "title": "EnvDrift",
      "properties": {
        "envdrift.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic encryption of .env files on close"
        },
        "envdrift.patterns": {
          "type": "array",
          "default": [
            ".env*"
          ],
          "items": {
            "type": "string"
          },
          "description": "File patterns to watch for encryption"
        },
        "envdrift.exclude": {
          "type": "array",
          "default": [
            ".env.example",
            ".env.sample",
            ".env.keys"
          ],
          "items": {
            "type": "string"
          },
          "description": "File patterns to exclude from encryption"
        },
        "envdrift.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when files are encrypted"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "pretest": "npm run compile && npm run bundle",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha --ui tdd ./out/test/unit/**/*.test.js"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "brace-expansion": "^5.0.6",
    "diff": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^24.0.0",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.0.0",
    "glob": "^13.0.0",
    "mocha": "^11.0.0",
    "sinon": "^22.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6"
  }
}
